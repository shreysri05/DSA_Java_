class Solution {
    public int[] twoSum(int[] nums, int target) { 
        int []result= new int[2];
       for (int i=0;i<nums.length;i++)
      {
         for (int j=i+1;j<nums.length;j++)
         {
            if(nums[i]+nums[j]==target)
            {
           result[0]=i;
           result[1]=j;
            break; // for breaking the inner loop 
            }
       }  } return result; // returning since the  function consists of int return type
    }
    
} 
