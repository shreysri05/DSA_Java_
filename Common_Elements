class Solution {
    public static ArrayList<Integer> commonElements(int a[], int b[]) {
       Arrays.sort(a);
       Arrays.sort(b);
       int i=0 ,j=0;
       ArrayList<Integer> ans = new ArrayList<>();
       while(i<a.length && j<b.length){
           if(a[i]==b[j]){
               ans.add(a[i]);
               i++;
               j++;
           }
           else if(a[i]>b[j]){
               j++;
           } else  i++;
       }
       return ans;
    }
}
