class Solution {
    public static int largest(int[] arr) {
        int max = arr[0]; //initialising max variable as the frst element of array
        for (int i = 1; i < arr.length; i++) { 
            if (arr[i] > max) {
                max = arr[i]; 
            }
        }
        return max;
    }

    public static void main(String[] args) {
        int[] arr = {1, 8, 7, 56, 90};
        System.out.println(largest(arr)); 
    }
}
