class Solution {
    public int[] countOddEven(int[] arr) {
     int []result=new int [2] ;
      int n = arr.length;
      int odd=0,even=0;
      for(int i =0;i<n;i++)
        {
            if (arr[i]%2==0)
          {  even++;}
          else{odd++;}
        } result[0]=odd;
        result[1]=even;
        return result;
    }
}
