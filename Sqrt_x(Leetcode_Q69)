class Solution {
    public int mySqrt(int n) {
   
        if (n==0)return n ;
       int low=1,high=n;
       while(low<=high){
           int mid = low+(-low+high)/2;
           if (mid==n/mid){ return mid;}
           else if (mid>n/mid){ high = mid-1;}
           else{ low =mid+1;}      
           }
        return high;
    }
}
  
